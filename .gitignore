# ═══════════════════════════════════════════════════════════════════════════
# .gitignore — Playwright TestNG Hybrid Framework
#
# RULE OF THUMB:
#   Commit everything a new developer needs to build and run the project.
#   Ignore everything that is generated, personal, or environment-specific.
# ═══════════════════════════════════════════════════════════════════════════


# ─── Maven build output ───────────────────────────────────────────────────
# The entire target/ directory is regenerated by "mvn compile" or "mvn test".
# Committing it bloats the repo with binaries that change on every build.
target/


# ─── Generated test data ──────────────────────────────────────────────────
# TestData.xlsx is a BINARY artifact produced by ExcelDataGenerator.java.
# The Java file is the true source of truth — commit that, not the output.
# To regenerate:
#   mvn test-compile exec:java -Dexec.classpathScope=test \
#       -Dexec.mainClass="com.automation.utils.ExcelDataGenerator"
src/test/resources/testdata/*.xlsx
src/test/resources/testdata/*.xls


# ─── Test execution output ────────────────────────────────────────────────
# Reports, screenshots, and logs are produced at runtime.
# They are large, binary-heavy, and change on every run — not useful in git.
# Share reports as CI pipeline artifacts instead.
test-output/


# ─── IntelliJ IDEA ────────────────────────────────────────────────────────
# .idea/ contains personal IDE settings (window layout, recent files, etc.)
# that differ between developers and should not be forced on the team.
# Exception: .idea/runConfigurations/ CAN be committed if the team agrees
# to share Run Configurations — uncomment the negation line below to do so.
.idea/
*.iml
*.iws
*.ipr
# !.idea/runConfigurations/


# ─── Eclipse ──────────────────────────────────────────────────────────────
.classpath
.project
.settings/
*.launch
bin/


# ─── VS Code ──────────────────────────────────────────────────────────────
.vscode/


# ─── NetBeans ─────────────────────────────────────────────────────────────
nbproject/
nbbuild/
nbdist/
nb-configuration.xml


# ─── Log files ────────────────────────────────────────────────────────────
# Logs are runtime artifacts; use the CI artifact store for post-run analysis.
*.log
*.log.*


# ─── OS metadata ──────────────────────────────────────────────────────────
# These are generated silently by the OS and have no meaning in source control.
.DS_Store           # macOS Finder metadata
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db         # Windows Explorer thumbnail cache
Thumbs.db
desktop.ini
$RECYCLE.BIN/


# ─── Environment / secrets ────────────────────────────────────────────────
# Never commit real credentials or environment-specific overrides.
# Use CI/CD secrets (GitHub Actions secrets, Jenkins credentials) instead.
.env
.env.*
*.secret
local.properties
local-override.properties


# ─── Java compiled artefacts ──────────────────────────────────────────────
# .class files live inside target/ which is already ignored above.
# These patterns catch any stray compilations outside the standard layout.
*.class
*.jar
*.war
*.ear
hs_err_pid*


# ─── Playwright browser cache ─────────────────────────────────────────────
# Playwright downloads browser binaries to the OS user cache directory
# (%USERPROFILE%\AppData\Local\ms-playwright on Windows), NOT the project
# folder. Listed here as a safety net in case a custom PLAYWRIGHT_BROWSERS_PATH
# points inside the project.
.playwright/
playwright-browsers/


# ─── Claude Code internal tooling ─────────────────────────────────────────
# .github/java-upgrade/ contains Claude Code hook scripts used during
# development. They are not part of the framework source and should not
# be pushed. Actual GitHub Actions workflows (if added later) would live
# in .github/workflows/ and should NOT be ignored.
.github/java-upgrade/
